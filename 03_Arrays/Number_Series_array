//Sum of first and last digit of a number

import java.util.Scanner;

public class first_last {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int size=sc.nextInt();
        System.out.print("Enter the number series:");
        int[] arr=new int[size];

        for (int i=0;i<size;i++){
            arr[i]=sc.nextInt();
        }

        int sum=arr[0]+arr[size-1];

        System.out.print("Sum of first and last digit:"+sum);
    }
}

//Sum of odd and even digits in a number

import java.util.Scanner;

//Initialise main class and method
public class sum_even_odd {
    public static void main(String[] args){
        //get method
        Scanner sc=new Scanner(System.in);
        
        //get input details
        System.out.print("Enter the size  of numbers:");
        int size=sc.nextInt();
        System.out.print("Enter the numbers:");
        int[] arr=new int[size];
        
        
        //get array
        for(int i=0;i<size;i++){
            arr[i]=sc.nextInt();
        }

        //initialise variables
        int even=0;
        int odd=0;

        //perform loop operation
        for (int i=0;i<size;i++){
            if(arr[i]%2 == 0){
                even+=arr[i];
            }
            else{
                odd+=arr[i];
            }
        }
        //print output
        System.out.println("Sum of even numbers:"+even);
        System.out.println("Sum of odd numbers:"+odd);
    }
}
